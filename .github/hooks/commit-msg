#!/bin/bash
# Git commit message hook
# 检查提交信息是否符合规范

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 跳过 merge 提交
if echo "$commit_msg" | grep -qE "^Merge"; then
    exit 0
fi

# 跳过 revert 提交
if echo "$commit_msg" | grep -qE "^Revert"; then
    exit 0
fi

# 提交信息格式：<类型>(<范围>): <描述>
# 范围是可选的
commit_regex='^(feat|fix|docs|style|refactor|perf|test|chore|build|ci)(\(.+\))?: .{1,50}'

if ! echo "$commit_msg" | grep -qE "$commit_regex"; then
    echo -e "${RED}❌ 提交信息格式错误！${NC}"
    echo ""
    echo -e "${YELLOW}正确格式：${NC}"
    echo "  <类型>(<范围>): <简短描述>"
    echo ""
    echo -e "${YELLOW}示例：${NC}"
    echo "  feat(converter): 添加温度转换功能"
    echo "  fix(calculator): 修复除零错误"
    echo "  docs(readme): 更新安装说明"
    echo ""
    echo -e "${YELLOW}支持的类型：${NC}"
    echo "  feat, fix, docs, style, refactor, perf, test, chore, build, ci"
    echo ""
    echo -e "${YELLOW}你的提交信息：${NC}"
    echo "  $commit_msg"
    echo ""
    echo -e "${YELLOW}详细规范请查看：${NC} .github/COMMIT_CONVENTION.md"
    exit 1
fi

# 检查标题行长度（中文字符算 2 个字符）
title_line=$(echo "$commit_msg" | head -n 1)
title_length=$(echo -n "$title_line" | wc -m)

if [ "$title_length" -gt 72 ]; then
    echo -e "${YELLOW}⚠️  警告：标题行过长（${title_length} 字符）${NC}"
    echo "  建议不超过 50 个字符（中文约 25 个字符）"
    echo ""
fi

echo -e "${GREEN}✅ 提交信息格式正确${NC}"
exit 0
